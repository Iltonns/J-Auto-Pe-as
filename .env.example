# CONFIGURAÇÕES DO BANCO DE DADOS NEON POSTGRESQL
# Copie este arquivo para .env e preencha com suas credenciais reais

# URL de conexão do Neon
# Formato: postgresql://usuario:senha@host/database?sslmode=require
DATABASE_URL=postgresql://neondb_owner:SUA_SENHA@ep-seu-endpoint.us-east-1.aws.neon.tech/neondb?sslmode=require

# Chave secreta do Flask (gere uma aleatória para produção)
SECRET_KEY=sua-chave-secreta-super-segura-mude-isso

# Ambiente (development ou production)
FLASK_ENV=production

# Descomente para desenvolvimento local
# FLASK_DEBUG=True

# ===============================
# CONFIGURACOES DO SERVICO NF-e
# ===============================
# Provedor de emissao: mock (simulacao), http (provedor externo)
NFE_PROVIDER=mock

# Ambiente fiscal (homologacao/producao)
NFE_AMBIENTE=homologacao

# Serie padrao das notas
NFE_SERIE_PADRAO=1

# Configuracoes para provedor HTTP (obrigatorio quando NFE_PROVIDER=http)
NFE_API_BASE_URL=
NFE_API_TOKEN=
NFE_EMISSAO_ENDPOINT=/nfe
NFE_TIMEOUT_SECONDS=30

# Token opcional para validar callbacks/webhooks de retorno
NFE_WEBHOOK_TOKEN=
